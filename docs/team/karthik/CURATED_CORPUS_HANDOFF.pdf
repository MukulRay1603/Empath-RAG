() Tj
T*
(    import json) Tj
T*
(    from pathlib import Path) Tj
T*
() Tj
T*
(    path = Path\("resources_seed.jsonl"\)) Tj
T*
(    seen = set\(\)) Tj
T*
() Tj
T*
(    for line_no, line in enumerate\(path.read_text\(encoding="utf-8"\).splitlines\(\), 1\):) Tj
T*
(        row = json.loads\(line\)) Tj
T*
(        assert row["id"] not in seen, f"duplicate id on line {line_no}") Tj
T*
(        seen.add\(row["id"]\)) Tj
T*
(        for field in [) Tj
T*
(            "id", "source_id", "source_name", "source_type", "title", "url",) Tj
T*
(            "topic", "audience", "risk_level", "usage_mode", "text",) Tj
T*
(            "summary", "last_checked", "notes") Tj
T*
(        ]:) Tj
T*
(            assert row.get\(field\), f"missing {field} on line {line_no}") Tj
